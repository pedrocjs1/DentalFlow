{
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "has": [{ "type": "host", "value": "admin.dentiqa.app" }],
      "destination": "/api/v1/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "admin.dentiqa.app" }],
      "destination": "/admin/:path*"
    }
  ]
}
