generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// MULTI-TENANCY & AUTH
// ═══════════════════════════════════════

model Tenant {
  id                    String             @id @default(cuid())
  name                  String
  slug                  String             @unique
  plan                  Plan               @default(STARTER)
  phone                 String?
  email                 String?
  address               String?
  city                  String?
  country               String             @default("AR")
  timezone              String             @default("America/Argentina/Buenos_Aires")
  logoUrl               String?
  welcomeMessage        String?
  currency              String             @default("ARS")
  settings              Json               @default("{}")
  // Bot configuration per clinic
  botTone               String             @default("friendly") // "formal" | "friendly" | "casual"
  botLanguage           String             @default("es")       // "es" | "pt" | "en"
  askBirthdate          Boolean            @default(true)
  askInsurance          Boolean            @default(true)
  offerDiscounts        Boolean            @default(false)
  maxDiscountPercent    Int                @default(10)          // 5-25
  proactiveFollowUp     Boolean            @default(true)
  leadRecontactHours    Int                @default(4)           // 0 | 2 | 4 | 12 | 24
  campaignBirthday      Boolean            @default(true)
  campaignPeriodicReminder Boolean         @default(true)
  campaignReactivation  Boolean            @default(true)
  messageDebounceSeconds Int               @default(12)          // 10-20
  askEmail              Boolean            @default(true)
  // Registration config — what data to collect from new patients
  registrationEnabled         Boolean  @default(true)
  askFullName                 Boolean  @default(true)
  askAddress                  Boolean  @default(false)
  askMedicalConditions        Boolean  @default(false)
  askAllergies                Boolean  @default(false)
  askMedications              Boolean  @default(false)
  askHabits                   Boolean  @default(false)
  registrationWelcomeMessage  String?
  // WhatsApp Embedded Signup — each clinic connects their own WABA
  wabaId                String?            // WhatsApp Business Account ID
  whatsappPhoneNumberId String?            // Meta phone_number_id
  whatsappDisplayNumber String?            // Human-readable phone number
  whatsappAccessToken   String?            // Encrypted access token (AES-256-GCM)
  whatsappConnectedAt   DateTime?
  whatsappStatus        WhatsAppStatus     @default(DISCONNECTED)
  stripeCustomerId      String?
  mpCustomerId          String?
  subscriptionStatus    SubscriptionStatus @default(TRIALING)
  trialEndsAt           DateTime?
  isActive              Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  users                 User[]
  patients              Patient[]
  appointments          Appointment[]
  dentists              Dentist[]
  chairs                Chair[]
  conversations         Conversation[]
  campaigns             Campaign[]
  pipelineStages        PipelineStage[]
  automations           Automation[]
  treatments            TreatmentType[]
  workingHours          WorkingHours[]
  faqEntries            FaqEntry[]
  medicalHistories      MedicalHistory[]
  odontogramFindings    OdontogramFinding[]
  treatmentPlans        TreatmentPlan[]
  treatmentPlanItems    TreatmentPlanItem[]
  visitNotes            ClinicalVisitNote[]
  periodontogramEntries PeriodontogramEntry[]
  dentistWorkingHours   DentistWorkingHours[]
  googleCalendarTokens  GoogleCalendarToken[]
  dentistTreatments     DentistTreatment[]
  usageRecords          UsageRecord[]
  whatsappTemplates     WhatsAppTemplate[]
  disabledTemplateIds   String[]           @default([]) // Template IDs disabled for this clinic
  notifications         Notification[]
  subscription          Subscription?
  // Historial clínico profesional
  odontogramVersions      OdontogramVersion[]
  periodontogramVersions  PeriodontogramVersion[]
  patientImages           PatientImage[]
  prescriptions           Prescription[]
  consentTemplates        ConsentTemplate[]
  patientConsents         PatientConsent[]
  evolutionTemplates      EvolutionTemplate[]
  plaqueRecords           PlaqueRecord[]
  medicalHistoryAudits    MedicalHistoryAudit[]
}

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

enum WhatsAppStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  name         String
  passwordHash String
  role         UserRole  @default(RECEPTIONIST)
  phone        String?
  avatarUrl    String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum UserRole {
  OWNER
  ADMIN
  DENTIST
  RECEPTIONIST
}

// ═══════════════════════════════════════
// CLÍNICA & AGENDA
// ═══════════════════════════════════════

model Dentist {
  id                  String                @id @default(cuid())
  tenantId            String
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId              String?
  name                String
  specialty           String?
  licenseNumber       String?
  phone               String?
  email               String?
  photoUrl            String?
  birthdate           DateTime?
  color               String                @default("#3B82F6")
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  appointments        Appointment[]
  workingHours        DentistWorkingHours[]
  googleCalendarToken GoogleCalendarToken?
  treatments          DentistTreatment[]
  // Historial clínico profesional
  prescriptions       Prescription[]
  consents            PatientConsent[]
  treatmentPlansLed   TreatmentPlan[]   @relation("TreatmentPlanDentist")

  @@index([tenantId])
}

model Chair {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  isActive     Boolean       @default(true)
  appointments Appointment[]

  @@index([tenantId])
}

model WorkingHours {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  startTime  String
  endTime    String
  breakStart String?
  breakEnd   String?
  isActive   Boolean @default(true)

  @@unique([tenantId, dayOfWeek])
  @@index([tenantId])
}

model TreatmentType {
  id           String             @id @default(cuid())
  tenantId     String
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  durationMin  Int                @default(30)
  price        Decimal?           @db.Decimal(10, 2)
  color        String?
  isActive     Boolean            @default(true)
  // Follow-up cycle
  followUpEnabled      Boolean    @default(false)
  followUpMonths       Int        @default(6)
  postProcedureCheck   Boolean    @default(false)
  postProcedureDays    Int        @default(7)
  followUpMessage      String?
  isMultiSession       Boolean    @default(false)  // true = ortodoncia, implantes (multi-visit)
  appointments Appointment[]
  dentists     DentistTreatment[]

  @@index([tenantId])
}

model DentistTreatment {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dentistId       String
  dentist         Dentist       @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  treatmentTypeId String
  treatmentType   TreatmentType @relation(fields: [treatmentTypeId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([dentistId, treatmentTypeId])
  @@index([tenantId])
  @@index([dentistId])
}

model Appointment {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  dentistId       String
  dentist         Dentist           @relation(fields: [dentistId], references: [id])
  chairId         String?
  chair           Chair?            @relation(fields: [chairId], references: [id])
  treatmentTypeId String?
  treatmentType   TreatmentType?    @relation(fields: [treatmentTypeId], references: [id])
  startTime       DateTime
  endTime         DateTime
  status          AppointmentStatus @default(CONFIRMED)
  notes           String?
  source          AppointmentSource @default(MANUAL)
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  reminderSent    Boolean           @default(false)
  postCheckSent   Boolean           @default(false)
  googleEventId   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  conversationId  String?

  @@index([tenantId])
  @@index([tenantId, dentistId, startTime])
  @@index([tenantId, patientId])
  @@index([tenantId, startTime])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentSource {
  MANUAL
  CHATBOT
  ONLINE
  PHONE
  DENTALINK
}

// ═══════════════════════════════════════
// PACIENTES & CRM
// ═══════════════════════════════════════

model Patient {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  phone        String
  email        String?
  birthdate    DateTime?
  insurance    String?            // Obra social / seguro dental
  gender       Gender?
  address      String?
  notes        String?
  tags         String[]      @default([])
  source       PatientSource @default(MANUAL)
  externalId   String?
  lastVisitAt  DateTime?
  nextVisitDue DateTime?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  appointments            Appointment[]
  conversations           Conversation[]
  pipelineEntry           PatientPipeline?
  campaignSends           CampaignSend[]
  clinicalNotes           ClinicalNote[]
  medicalHistory          MedicalHistory?
  odontogramFindings      OdontogramFinding[]
  treatmentPlans          TreatmentPlan[]
  visitNotes              ClinicalVisitNote[]
  periodontogram          PeriodontogramEntry[]
  // Historial clínico profesional
  odontogramVersions      OdontogramVersion[]
  periodontogramVersions  PeriodontogramVersion[]
  images                  PatientImage[]
  prescriptions           Prescription[]
  consents                PatientConsent[]
  plaqueRecords           PlaqueRecord[]
  medicalHistoryAudits    MedicalHistoryAudit[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, birthdate])
  @@index([tenantId, nextVisitDue])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PatientSource {
  MANUAL
  CHATBOT
  ONLINE
  REFERRAL
  CAMPAIGN
  DENTALINK
}

model ClinicalNote {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  authorId  String
  content   String
  type      NoteType @default(GENERAL)
  createdAt DateTime @default(now())

  @@index([patientId])
}

enum NoteType {
  GENERAL
  TREATMENT
  DIAGNOSIS
  FOLLOW_UP
}

// ═══════════════════════════════════════
// HISTORIAL CLÍNICO
// ═══════════════════════════════════════

model MedicalHistory {
  id                String    @id @default(cuid())
  patientId         String    @unique
  patient           Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  bloodType         String?
  rhFactor          String?               // "+", "-"
  allergies         String[]  @default([])
  medications       String[]  @default([])
  hasDiabetes       Boolean   @default(false)
  hasHypertension   Boolean   @default(false)
  hasHeartDisease   Boolean   @default(false)
  hasAsthma         Boolean   @default(false)
  hasHIV            Boolean   @default(false)
  hasEpilepsy       Boolean   @default(false)
  otherDiseases     String?
  hasBruxism        Boolean   @default(false)
  isSmoker          Boolean   @default(false)
  smokingDetails    String?
  surgicalHistory   String?
  hospitalizations  String?
  isPregnant        Boolean   @default(false)
  lastDoctorVisit   DateTime?
  consentSigned     Boolean   @default(false)
  consentSignedAt   DateTime?
  consentNotes      String?
  // Campos mejorados — Historial Clínico Profesional
  primaryDoctor         String?
  primaryDoctorPhone    String?
  latexAllergy          Boolean   @default(false)
  anestheticAllergy     Boolean   @default(false)
  allergyDetails        Json?     // [{ name, severity: "MILD"|"MODERATE"|"SEVERE" }]
  medicationDetails     Json?     // [{ name, dose, frequency, since }]
  conditionDetails      Json?     // [{ name, type, since, currentTreatment, isActive }]
  familyHistory         Json?     // { diabetes, hypertension, cancer, heartDisease, other }
  smokingAmount         String?   // "5 por día"
  alcoholFrequency      String?   // "Ocasional", "Semanal"
  pregnancyWeeks        Int?
  breastfeeding         Boolean   @default(false)
  surgeryHistory        Json?     // [{ name, date, hospital, notes }]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tenantId])
}

model OdontogramFinding {
  id          String           @id @default(cuid())
  patientId   String
  patient     Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  toothFdi    Int
  surface     ToothSurface?
  condition   ToothCondition
  status      OdontogramStatus @default(EXISTING)
  notes       String?
  recordedBy  String
  // Campos mejorados — Historial Clínico Profesional
  diagnosis              String?
  dentistId              String?
  linkedTreatmentItemId  String?
  versionId              String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([tenantId])
  @@index([patientId])
  @@index([patientId, toothFdi])
}

enum ToothSurface {
  OCCLUSAL
  MESIAL
  DISTAL
  VESTIBULAR
  LINGUAL
}

enum ToothCondition {
  HEALTHY
  CARIES
  RESTORATION_AMALGAM
  RESTORATION_RESIN
  RESTORATION_IONOMER
  CROWN
  ENDODONTICS
  EXTRACTION
  IMPLANT
  PROSTHESIS
  FRACTURE
  SEALANT
  ABSENT
}

enum OdontogramStatus {
  EXISTING
  PLANNED
}

model TreatmentPlan {
  id        String      @id @default(cuid())
  patientId String
  patient   Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  title     String      @default("Plan de Tratamiento")
  notes     String?
  isActive  Boolean     @default(true)
  // Campos mejorados — Presupuesto profesional
  status          String    @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  dentistId       String?
  dentist         Dentist?  @relation("TreatmentPlanDentist", fields: [dentistId], references: [id])
  totalAmount     Float     @default(0)
  discountPercent Float     @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  items     TreatmentPlanItem[]

  @@index([tenantId])
  @@index([patientId])
}

model TreatmentPlanItem {
  id            String              @id @default(cuid())
  planId        String
  plan          TreatmentPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  toothFdi      Int?
  procedureName String
  status        TreatmentItemStatus @default(PENDING)
  unitCost      Decimal             @default(0) @db.Decimal(10, 2)
  quantity      Int                 @default(1)
  notes         String?
  sortOrder     Int                 @default(0)
  completedAt   DateTime?
  // Campos mejorados — Presupuesto profesional
  discountPercent Float             @default(0)
  section         String?           // "Fase 1: Urgencia"
  completedById   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([planId])
  @@index([tenantId])
}

enum TreatmentItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ClinicalVisitNote {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  authorId      String
  visitDate     DateTime @default(now())
  toothNumbers  Int[]    @default([])
  procedureName String?
  materials     String?
  content       String
  nextStep      String?
  attachments   Json     @default("[]")
  // Campos mejorados — Evoluciones profesionales
  dentistId            String?
  treatmentPlanId      String?
  treatmentPlanItemId  String?
  diagnosis            String?
  signaturePatient     String?  @db.Text
  signatureDentist     String?  @db.Text
  templateUsed         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([patientId])
  @@index([patientId, visitDate])
}

model PeriodontogramEntry {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  recordedBy  String
  recordedAt  DateTime @default(now())
  findings    Json     @default("{}")
  notes       String?
  // Campos mejorados — Periodontograma profesional
  furca        String?   // "NONE", "I", "II", "III"
  suppuration  Boolean   @default(false)
  plaque       Boolean   @default(false)
  versionId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([patientId])
  @@index([patientId, recordedAt])
}

// ═══════════════════════════════════════
// PIPELINE CRM
// ═══════════════════════════════════════

model PipelineStage {
  id            String            @id @default(cuid())
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  order         Int
  color         String            @default("#6B7280")
  isDefault     Boolean           @default(false)
  // Automation config
  autoMessageEnabled    Boolean   @default(false)
  autoMessageDelayHours Int       @default(24)
  autoMessageTemplate   String?
  autoMessageMaxRetries Int       @default(1)
  autoMoveEnabled       Boolean   @default(false)
  autoMoveDelayHours    Int       @default(48)
  autoMoveTargetStageId String?
  discountEnabled       Boolean   @default(false)
  discountPercent       Int       @default(10)
  discountMessage       String?
  discountTemplate      String?
  patients      PatientPipeline[]

  @@unique([tenantId, order])
  @@index([tenantId])
}

model PatientPipeline {
  id                    String        @id @default(cuid())
  patientId             String        @unique
  patient               Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  stageId               String
  stage                 PipelineStage @relation(fields: [stageId], references: [id])
  movedAt               DateTime      @default(now())
  notes                 String?
  interestTreatment     String?
  lastAutoMessageSentAt DateTime?
  lastManualMoveAt      DateTime?

  @@index([stageId])
  @@index([movedAt])
}

// ═══════════════════════════════════════
// CONVERSACIONES & MENSAJES (WhatsApp)
// ═══════════════════════════════════════

model Conversation {
  id                 String             @id @default(cuid())
  tenantId           String
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId          String
  patient            Patient            @relation(fields: [patientId], references: [id])
  channel            Channel            @default(WHATSAPP)
  status             ConversationStatus @default(OPEN)
  assignedToId       String?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  aiEnabled          Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  messages Message[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, patientId])
}

enum Channel {
  WHATSAPP
  EMAIL
  WEB_CHAT
  SMS
}

enum ConversationStatus {
  OPEN
  AI_HANDLING
  HUMAN_NEEDED
  CLOSED
}

model Message {
  id                String           @id @default(cuid())
  conversationId    String
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction         MessageDirection
  content           String
  type              MessageType      @default(TEXT)
  mediaUrl          String?
  whatsappMessageId String?
  metadata          Json?
  sentAt            DateTime         @default(now())
  deliveredAt       DateTime?
  readAt            DateTime?

  @@index([conversationId])
  @@index([conversationId, sentAt])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  DOCUMENT
  TEMPLATE
  INTERACTIVE
}

// ═══════════════════════════════════════
// CAMPAÑAS & MARKETING
// ═══════════════════════════════════════

model Campaign {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  type            CampaignType
  channel         Channel        @default(WHATSAPP)
  status          CampaignStatus @default(DRAFT)
  templateName    String?
  templateParams  Json?
  messageContent  String?
  subject         String?
  segmentFilter   Json?
  triggerType     TriggerType?
  triggerConfig   Json?
  scheduledAt     DateTime?
  sentAt          DateTime?
  completedAt     DateTime?
  totalSent       Int            @default(0)
  totalDelivered  Int            @default(0)
  totalRead       Int            @default(0)
  totalClicked    Int            @default(0)
  totalReplied    Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  sends CampaignSend[]

  @@index([tenantId])
  @@index([tenantId, type, status])
}

enum CampaignType {
  MANUAL
  BIRTHDAY
  REMINDER_6M
  REMINDER_24H
  REACTIVATION
  PROMO
  WELCOME
  POST_VISIT
  CUSTOM
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  PAUSED
  CANCELLED
}

enum TriggerType {
  DATE_FIELD
  EVENT
  TIME_AFTER_EVENT
  CRON
}

model CampaignSend {
  id                String     @id @default(cuid())
  campaignId        String
  campaign          Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  patientId         String
  patient           Patient    @relation(fields: [patientId], references: [id])
  status            SendStatus @default(PENDING)
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  clickedAt         DateTime?
  repliedAt         DateTime?
  errorMessage      String?
  whatsappMessageId String?

  @@index([campaignId])
  @@index([patientId])
}

enum SendStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
}

// ═══════════════════════════════════════
// WHATSAPP TEMPLATES (GLOBAL — system templates have no tenant)
// ═══════════════════════════════════════

model WhatsAppTemplate {
  id               String    @id @default(cuid())
  // System templates are global (tenantId = null). Custom clinic templates have tenantId.
  tenantId         String?
  tenant           Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String                 // Only lowercase, numbers, underscores (Meta requirement)
  displayName      String    @default("") // Human-readable name for the dashboard
  description      String?               // When to use this template
  category         String                 // UTILITY, MARKETING
  language         String    @default("es_AR")
  // Content (Meta API components format)
  headerType       String?                // TEXT, IMAGE, VIDEO, DOCUMENT, NONE
  headerText       String?
  bodyText         String                 // Body with variables {{1}}, {{2}}, etc.
  footerText       String?
  buttonsJson      Json?                  // Buttons CTA or quick reply
  // Variables mapping
  variablesJson    Json?                  // [{position: 1, field: "firstName", example: "Pedro"}, ...]
  // Meta approval state
  status           String    @default("DRAFT") // DRAFT, SUBMITTED, PENDING, APPROVED, REJECTED, PAUSED, DISABLED
  metaTemplateId   String?                // ID returned by Meta on creation
  metaStatus       String?                // Raw status from Meta (for sync)
  rejectionReason  String?
  qualityScore     String?                // GREEN, YELLOW, RED (Meta quality rating)
  // Timeline
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  submittedAt      DateTime?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  lastCheckedAt    DateTime?              // Last time status was checked on Meta
  // Control
  isSystemTemplate Boolean   @default(true)  // true = created by Super Admin
  isActive         Boolean   @default(true)
  version          Int       @default(1)
  // Suggested usage
  suggestedTrigger String?                // "appointment_reminder", "follow_up", "reactivation", etc.

  events           TemplateEvent[]

  @@index([status])
  @@index([isSystemTemplate, status])
  @@index([tenantId])
}

model TemplateEvent {
  id          String           @id @default(cuid())
  templateId  String
  template    WhatsAppTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  event       String           // "created", "submitted", "approved", "rejected", "resubmitted", "paused", "disabled", "edited", "status_check"
  details     String?          // Event detail (e.g. rejection reason, who edited)
  metadata    Json?            // Extra data (Meta API response, etc.)
  createdAt   DateTime         @default(now())

  @@index([templateId, createdAt])
}

// ═══════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?               // null = all users in tenant
  type      String                // new_patient, new_appointment, cancelled_appointment, etc.
  category  String    @default("system") // messages, system, pipeline, ai
  title     String
  message   String
  link      String?               // In-app URL (e.g., /pipeline, /agenda)
  isRead    Boolean   @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([tenantId, isRead])
  @@index([tenantId, createdAt])
  @@index([tenantId, category])
}

// ═══════════════════════════════════════
// AUTOMATIZACIONES
// ═══════════════════════════════════════

model Automation {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  triggerEvent    String
  conditions      Json      @default("[]")
  actions         Json      @default("[]")
  isActive        Boolean   @default(true)
  executionCount  Int       @default(0)
  lastExecutedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, triggerEvent])
}

// ═══════════════════════════════════════
// FAQs (para el chatbot)
// ═══════════════════════════════════════

model FaqEntry {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// ═══════════════════════════════════════
// AGENDA — HORARIOS POR DENTISTA & GOOGLE CALENDAR
// ═══════════════════════════════════════

model DentistWorkingHours {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dentistId  String
  dentist    Dentist @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  dayOfWeek  Int     // 1=Mon, 2=Tue, ..., 6=Sat, 0=Sun
  startTime  String  // "09:00"
  endTime    String  // "18:00"
  isActive   Boolean @default(true)

  @@unique([dentistId, dayOfWeek])
  @@index([tenantId])
}

model GoogleCalendarToken {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dentistId    String   @unique
  dentist      Dentist  @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  accessToken  String   // AES-256-GCM encrypted
  refreshToken String   // AES-256-GCM encrypted
  expiresAt    DateTime
  calendarId   String   @default("primary")
  syncEnabled  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

// ═══════════════════════════════════════
// SUBSCRIPTIONS & BILLING
// ═══════════════════════════════════════

model Subscription {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  plan        String   @default("PROFESSIONAL")  // STARTER, PROFESSIONAL, ENTERPRISE
  status      String   @default("TRIALING")      // TRIALING, ACTIVE, PAST_DUE, CANCELLED, SUSPENDED

  // Trial period
  trialStartDate     DateTime  @default(now())
  trialEndDate       DateTime?

  // Billing period
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime?
  paymentMethod      String?   // "transfer", "mercadopago", "stripe", "pending"

  // Mercado Pago
  mpSubscriptionId     String?
  mpPayerId            String?
  mpLastPaymentId      String?
  cancelsAt            DateTime?
  failedPaymentAttempts Int       @default(0)

  // Stripe (future)
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // Control
  billingNotes    String?
  cancelledAt     DateTime?
  cancelReason    String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
}

// ═══════════════════════════════════════
// SUPER ADMIN
// ═══════════════════════════════════════

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ═══════════════════════════════════════
// USAGE TRACKING
// ═══════════════════════════════════════

model UsageRecord {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      UsageType
  quantity  Int       @default(1)
  period    String
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, type, period])
  @@index([period])
}

enum UsageType {
  WHATSAPP_MESSAGE
  AI_INTERACTION
  AI_TOKENS
  CAMPAIGN_SEND
  EMAIL_SEND
}

// ═══════════════════════════════════════
// HISTORIAL CLÍNICO PROFESIONAL (nuevos modelos)
// ═══════════════════════════════════════

model OdontogramVersion {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  versionNumber Int
  label         String?  // "Versión inicial", "Control 3 meses"
  findings      Json     // Snapshot de todos los findings al momento de crear la versión
  createdById   String?
  createdAt     DateTime @default(now())

  @@index([patientId, tenantId])
}

model PeriodontogramVersion {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  versionNumber Int
  label         String?
  entries       Json     // Snapshot completo del periodontograma
  metrics       Json?    // { bop, avgPD, avgNIC, plaqueIndex }
  createdById   String?
  createdAt     DateTime @default(now())

  @@index([patientId, tenantId])
}

model PatientImage {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  category      String   // RADIOGRAPHY, INTRAORAL, EXTRAORAL, DOCUMENT, OTHER
  description   String?
  fileName      String
  fileSize      Int
  mimeType      String
  imageData     String   @db.Text  // base64 para MVP
  toothNumbers  String?  // "16,17,18" piezas asociadas
  evolutionId   String?  // Si está asociada a una evolución
  uploadedById  String?
  createdAt     DateTime @default(now())

  @@index([patientId, tenantId])
  @@index([category])
}

model Prescription {
  id                 String   @id @default(cuid())
  patientId          String
  patient            Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  dentistId          String
  dentist            Dentist  @relation(fields: [dentistId], references: [id])
  evolutionId        String?  // Vinculada a una evolución (opcional)
  prescriptionNumber Int      // Auto-incremental por tenant
  diagnosis          String?
  medications        Json     // [{ name, dose, frequency, duration, route, instructions }]
  notes              String?
  templateUsed       String?  // Nombre de la plantilla usada
  signatureData      String?  @db.Text // Firma digital base64
  createdAt          DateTime @default(now())

  @@index([patientId, tenantId])
}

model ConsentTemplate {
  id            String           @id @default(cuid())
  tenantId      String
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  name          String           // "Consentimiento de extracción"
  category      String           // GENERAL, EXTRACTION, ENDODONTICS, SURGERY, ORTHODONTICS, WHITENING, DATA_PRIVACY
  content       String           @db.Text // Template con placeholders: {{patientName}}, {{date}}, etc.
  isActive      Boolean          @default(true)
  isDefault     Boolean          @default(false) // Templates del seed
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  consents      PatientConsent[]

  @@index([tenantId])
}

model PatientConsent {
  id               String           @id @default(cuid())
  patientId        String
  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  templateId       String?
  template         ConsentTemplate? @relation(fields: [templateId], references: [id])
  dentistId        String
  dentist          Dentist          @relation(fields: [dentistId], references: [id])
  title            String
  content          String           @db.Text // Contenido final renderizado
  status           String           @default("DRAFT") // DRAFT, SIGNED, REVOKED
  patientSignature String?          @db.Text // base64
  dentistSignature String?          @db.Text // base64
  signedAt         DateTime?
  revokedAt        DateTime?
  revokedReason    String?
  createdAt        DateTime         @default(now())

  @@index([patientId, tenantId])
}

model EvolutionTemplate {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String   // "Limpieza dental"
  procedure     String?  // Procedimiento pre-llenado
  materials     String?  // Materiales pre-llenados (comma separated)
  description   String?  @db.Text // Descripción base
  instructions  String?  @db.Text // Indicaciones post-procedimiento
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([tenantId])
}

model PlaqueRecord {
  id               String   @id @default(cuid())
  patientId        String
  patient          Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  affectedSurfaces Json     // { "16": ["V", "L", "M", "D", "O"], "17": ["V", "M"] }
  totalSurfaces    Int
  affectedCount    Int
  percentage       Float    // affectedCount / totalSurfaces * 100
  comments         String?
  createdById      String?
  createdAt        DateTime @default(now())

  @@index([patientId, tenantId])
}

model MedicalHistoryAudit {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  changedById  String
  fieldChanged String   // "allergies", "medications", "conditions"
  oldValue     String?  @db.Text
  newValue     String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([patientId, tenantId])
}
