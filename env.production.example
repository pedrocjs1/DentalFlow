# ═══════════════════════════════════════
# Dentiqa v1.0.0 — Production Environment Variables
# ═══════════════════════════════════════

# Database (Supabase) — use pooled for app, direct for migrations
DATABASE_URL=postgresql://postgres.XXX:PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL_DIRECT=postgresql://postgres.XXX:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# Redis (for BullMQ cron jobs)
REDIS_URL=redis://default:PASSWORD@host:6379

# Auth
JWT_SECRET=GENERATE-A-SECURE-64-CHAR-SECRET
JWT_EXPIRES_IN=7d

# Anthropic (Chatbot IA)
ANTHROPIC_API_KEY=sk-ant-...

# Google Calendar OAuth
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://api.dentiqa.app/api/v1/google-calendar/callback

# WhatsApp (Meta Cloud API)
WHATSAPP_APP_ID=1627937931777794
WHATSAPP_APP_SECRET=CHANGE-ME
WHATSAPP_CONFIGURATION_ID=1419326039498188
WHATSAPP_VERIFY_TOKEN=CHANGE-ME
WHATSAPP_ENABLED=true

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...

# Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=hola@dentiqa.app

# Storage (Supabase S3)
S3_BUCKET=patient-images
S3_REGION=us-west-2
S3_ACCESS_KEY=...
S3_SECRET_KEY=...
S3_ENDPOINT=https://XXX.storage.supabase.co/storage/v1/s3

# Encryption key for tokens stored in DB (32 bytes hex = 64 chars)
ENCRYPTION_KEY=GENERATE-A-64-CHAR-HEX-KEY

# URLs
APP_URL=https://dashboard.dentiqa.app
API_URL=https://api.dentiqa.app
LANDING_URL=https://dentiqa.app
ADMIN_URL=https://admin.dentiqa.app

# Node
NODE_ENV=production
