# ═══════════════════════════════════════
# Dentiqa v1.0.0 — Production Environment Variables
# ═══════════════════════════════════════

# Database (Supabase)
DATABASE_URL=postgresql://postgres:PASSWORD@host:5432/dentiqa

# Redis (for BullMQ cron jobs)
REDIS_URL=redis://default:PASSWORD@host:6379

# Auth
JWT_SECRET=GENERATE-A-SECURE-64-CHAR-SECRET
JWT_EXPIRES_IN=7d

# Anthropic (Chatbot IA)
ANTHROPIC_API_KEY=sk-ant-...

# Google Calendar OAuth
GOOGLE_CLIENT_ID=578113937794-gp21cgt1ajmcmjkbeh66g54nj62fu6rk.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://api.dentiqa.app/api/v1/gcal/callback

# WhatsApp (Meta Cloud API)
WHATSAPP_APP_ID=1627937931777794
WHATSAPP_APP_SECRET=CHANGE-ME
WHATSAPP_CONFIGURATION_ID=1419326039498188
WHATSAPP_VERIFY_TOKEN=CHANGE-ME
WHATSAPP_ENABLED=true

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-...

# Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=hola@dentiqa.app

# Storage (Cloudflare R2 / S3)
S3_BUCKET=dentiqa-uploads
S3_REGION=auto
S3_ACCESS_KEY=...
S3_SECRET_KEY=...
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com

# Encryption key for tokens stored in DB (32 bytes hex = 64 chars)
ENCRYPTION_KEY=GENERATE-A-64-CHAR-HEX-KEY

# URLs
APP_URL=https://dashboard.dentiqa.app
API_URL=https://api.dentiqa.app
LANDING_URL=https://dentiqa.app
ADMIN_URL=https://admin.dentiqa.app

# Node
NODE_ENV=production
